<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignInActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Авторизация"/>
    <TextView
        android:id="@+id/Login_TV_signIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="250dp"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Логин"/>
    <EditText
        android:id="@+id/Login_ET_signIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Login_TV_signIn"/>
    <TextView
        android:id="@+id/Password_TV"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Login_ET_signIn"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Пароль"/>
    <EditText
        android:id="@+id/Password_ET_signIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Password_TV"/>
    <Button
        android:id="@+id/SignUp_BT_signIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Регистрация"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <Button
        android:id="@+id/SignIn_BT_signIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Войти"
        android:textSize="20dp"
        app:layout_constraintBottom_toTopOf="@id/SignUp_BT_signIn"/>

</androidx.constraintlayout.widget.ConstraintLayout>