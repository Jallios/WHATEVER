<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SignUpActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Регистрация"/>
    <TextView
        android:id="@+id/Login_TV_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="250dp"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Логин"/>
    <EditText
        android:id="@+id/Login_ET_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Login_TV_signUp"/>
    <TextView
        android:id="@+id/Password_TV_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Login_ET_signUp"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Пароль"/>
    <EditText
        android:id="@+id/Password_ET_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Password_TV_signUp"/>
    <TextView
        android:id="@+id/Email_TV_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Password_ET_signUp"
        android:gravity="center"
        android:textSize="20dp"
        android:text="Email"/>
    <EditText
        android:id="@+id/Email_ET_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/Email_TV_signUp"/>
    <Button
        android:id="@+id/SignUp_BT_signUp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Регистрация"
        android:textSize="20dp"
        app:layout_constraintBottom_toBottomOf="parent"/>
    />

</androidx.constraintlayout.widget.ConstraintLayout>